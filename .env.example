# =============================================
# Pandoc Orchestrator — Environment Variables
# Firebase Configuration
# =============================================

# --- Firebase Web SDK (Frontend) ---
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"

# --- Firebase Admin SDK (Backend Worker) ---
# JSON dosyasının mutlak veya göreceli yolu
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"
# Storage Bucket adı (Storage servisi için gereklidir)
FIREBASE_STORAGE_BUCKET="your-project.appspot.com"

# --- Worker API ---
WORKER_API_URL="http://localhost:8000"
NEXT_PUBLIC_WORKER_API_URL="http://localhost:8000"
WORKER_MAX_TIMEOUT=120
WORKER_TEMP_DIR="/tmp/pandoc-workdir"
