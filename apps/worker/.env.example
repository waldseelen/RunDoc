# Pandoc Worker
WORKER_API_URL=http://localhost:8000
WORKER_TEMP_DIR=./temp_workdir
WORKER_MAX_TIMEOUT=120
WORKER_MAX_FILE_SIZE_MB=50
PANDOC_PATH=pandoc

# Security
WORKER_REQUIRE_AUTH=true
# Shared token fallback (for non-Firebase clients)
WORKER_API_TOKEN=change-me
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Firebase Admin
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
